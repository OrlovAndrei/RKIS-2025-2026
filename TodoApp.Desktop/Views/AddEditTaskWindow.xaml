<Window x:Class="TodoApp.Desktop.Views.AddEditTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TodoApp.Models;assembly=TodoApp.Models"
        Title="{Binding Title}" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Window.Resources>
        <ObjectDataProvider x:Key="TodoStatusValues" MethodName="GetValues" ObjectType="{x:Type models:TodoStatus}"/>
    </Window.Resources>

    <Border Background="White" Margin="10" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold" 
                       Margin="10,10,10,15" HorizontalAlignment="Center"/>
            
            <TextBlock Grid.Row="1" Text="Текст задачи:" Margin="10,5,0,5" FontWeight="Bold"/>
            <TextBox Grid.Row="2" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" 
                     AcceptsReturn="True" Height="120" Margin="10,0,10,10"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
            
            <TextBlock Grid.Row="3" Text="Статус:" Margin="10,5,0,5" FontWeight="Bold"/>
            <ComboBox Grid.Row="4" ItemsSource="{Binding Source={StaticResource TodoStatusValues}}" 
                      SelectedValue="{Binding Status}" Margin="10,0,10,10" Height="30"
                      VerticalAlignment="Top"/>
            
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                        Width="80" Height="30" Background="#4CAF50" Foreground="White" 
                        Margin="0,0,10,0" FontWeight="Bold"/>
                <Button Content="Отмена" Command="{Binding CancelCommand}" 
                        Width="80" Height="30" Background="#F44336" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>