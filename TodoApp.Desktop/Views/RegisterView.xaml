<UserControl x:Class="TodoApp.Desktop.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:TodoApp.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="400">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Регистрация" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
        
        <TextBox Grid.Row="1" Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Height="35" ToolTip="Логин"/>
        
        <PasswordBox Grid.Row="2" x:Name="PasswordBox" 
                     PasswordChanged="PasswordBox_PasswordChanged"
                     Margin="0,5" Height="35" ToolTip="Пароль"/>
        
        <TextBox Grid.Row="3" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Height="35" ToolTip="Имя"/>
        
        <TextBox Grid.Row="4" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Height="35" ToolTip="Фамилия"/>
        
        <TextBox Grid.Row="5" Text="{Binding BirthYear, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Height="35" ToolTip="Год рождения"/>
        
        <TextBlock Grid.Row="6" Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,5"/>
        
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="Зарегистрироваться" Command="{Binding RegisterCommand}" 
                    Width="140" Height="35" Margin="5"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" 
                    Width="80" Height="35" Margin="5"/>
        </StackPanel>
    </Grid>
</UserControl>