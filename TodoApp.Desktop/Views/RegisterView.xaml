<UserControl x:Class="TodoApp.Desktop.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F4F6F8">
        <Border Margin="28"
                Padding="34"
                Background="White"
                CornerRadius="28"
                MaxWidth="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Регистрация профиля"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#17324D" />
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,10,0,24"
                           Foreground="#61768D"
                           TextWrapping="Wrap" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,10,12">
                        <TextBlock Text="Логин" />
                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" Padding="12" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,12">
                        <TextBlock Text="Пароль" />
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" Padding="12" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,10,12">
                        <TextBlock Text="Имя" />
                        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" Padding="12" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,12">
                        <TextBlock Text="Фамилия" />
                        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" Padding="12" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,10,0">
                        <TextBlock Text="Год рождения" />
                        <TextBox Text="{Binding BirthYear, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" Padding="12" />
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                    <Button Content="Создать профиль"
                            Command="{Binding RegisterCommand}"
                            Padding="18,12"
                            Background="#1F8A70"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Margin="0,0,12,0" />
                    <Button Content="Назад"
                            Command="{Binding BackToLoginCommand}"
                            Padding="18,12"
                            Background="#F3F6FA"
                            BorderBrush="#D8E0E8" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
