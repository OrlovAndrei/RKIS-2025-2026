<UserControl x:Class="TodoApp.Desktop.Views.TodoListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TodoApp.Desktop.ViewModels"
             xmlns:converters="clr-namespace:TodoApp.Desktop.Converters"
             xmlns:models="clr-namespace:TodoApp.Models;assembly=TodoApp.Models"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TodoListViewModel}"
             d:DesignHeight="600" d:DesignWidth="900">
    
    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor" />
        
        <ObjectDataProvider x:Key="TodoStatusValues" MethodName="GetValues" ObjectType="{x:Type models:TodoStatus}"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Верхняя панель -->
        <Border DockPanel.Dock="Top" Background="#E0E0E0" Padding="10">
            <StackPanel>
                <TextBlock Text="{Binding CurrentProfile.FullName, StringFormat='Пользователь: {0}'}" 
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                
                <WrapPanel>
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Width="200" Margin="0,0,10,0" Height="30"/>
                    
                    <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource TodoStatusValues}}" 
                              SelectedValue="{Binding FilterStatus}" 
                              Width="120" Height="30" Margin="0,0,10,0"/>
                    
                    <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox SelectedValue="{Binding SortBy}" Width="100" Height="30" Margin="0,0,10,0">
                        <ComboBoxItem Content="По дате" Tag="date" IsSelected="True"/>
                        <ComboBoxItem Content="По тексту" Tag="text"/>
                    </ComboBox>
                    
                    <CheckBox Content="По убыванию" IsChecked="{Binding SortDescending}" 
                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                    
                    <Button Content="Добавить" Command="{Binding AddTaskCommand}" 
                            Height="30" Width="80" Background="#2196F3" Foreground="White" Margin="5,0"/>
                    
                    <Button Content="Редактировать" Command="{Binding EditTaskCommand}" 
                            IsEnabled="{Binding IsTaskSelected}" Height="30" Width="100" 
                            Background="#FF9800" Foreground="White" Margin="5,0"/>
                    
                    <Button Content="Удалить" Command="{Binding DeleteTaskCommand}" 
                            IsEnabled="{Binding IsTaskSelected}" Height="30" Width="80" 
                            Background="#F44336" Foreground="White" Margin="5,0"/>
                    
                    <Button Content="Выход" Command="{Binding LogoutCommand}" 
                            Height="30" Width="80" Background="#9E9E9E" 
                            Foreground="White" Margin="20,0,0,0"/>
                </WrapPanel>
                
                <TextBlock Text="{Binding StatusMessage}" Foreground="Blue" 
                           Margin="0,10,0,0" FontSize="12"/>
            </StackPanel>
        </Border>
        
        <!-- Список задач -->
        <ListView ItemsSource="{Binding Tasks}" 
                  SelectedItem="{Binding SelectedTask}" 
                  MouseDoubleClick="ListView_MouseDoubleClick"
                  AlternationCount="2">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#F5F5F5"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E3F2FD"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#BBDEFB"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Текст задачи" Width="350">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" MaxWidth="350"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Статус" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}" 
                                        CornerRadius="5" Padding="5,2" 
                                        HorizontalAlignment="Left" MinWidth="100">
                                    <TextBlock Text="{Binding Status}" Foreground="White" 
                                               FontWeight="Bold" TextAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Дата изменения" Width="150" 
                                    DisplayMemberBinding="{Binding LastUpdate, StringFormat='dd.MM.yyyy HH:mm'}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>