<UserControl x:Class="TodoApp.Desktop.Views.AddTaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F4F6F8">
        <Border Margin="28"
                Padding="34"
                Background="White"
                CornerRadius="28"
                MaxWidth="640"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Новая задача"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#17324D" />
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,10,0,24"
                           Foreground="#61768D"
                           TextWrapping="Wrap" />

                <TextBlock Text="Описание задачи" />
                <TextBox Text="{Binding TaskText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="180"
                         Margin="0,6,0,16"
                         Padding="12" />

                <TextBlock Text="Статус" />
                <ComboBox ItemsSource="{Binding AvailableStatuses}"
                          SelectedItem="{Binding SelectedStatus}"
                          Margin="0,6,0,24"
                          Padding="10" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="Сохранить"
                            Command="{Binding SaveCommand}"
                            Padding="18,12"
                            Background="#1F8A70"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Margin="0,0,12,0" />
                    <Button Content="Отмена"
                            Command="{Binding CancelCommand}"
                            Padding="18,12"
                            Background="#F3F6FA"
                            BorderBrush="#D8E0E8" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
