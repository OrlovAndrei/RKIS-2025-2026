<Application x:Class="TodoApp.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TodoApp.Desktop.Views"
             xmlns:viewModels="clr-namespace:TodoApp.Desktop.ViewModels">
    <Application.Resources>
        <DataTemplate DataType="{x:Type viewModels:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:RegisterViewModel}">
            <views:RegisterView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:TodoListViewModel}">
            <views:TodoListView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:AddTaskViewModel}">
            <views:AddTaskView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:EditTaskViewModel}">
            <views:EditTaskView />
        </DataTemplate>
    </Application.Resources>
</Application>
