<Application x:Class="TodoApp.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:TodoApp.Desktop.ViewModels"
             xmlns:views="clr-namespace:TodoApp.Desktop.Views">
    <Application.Resources>
        <DataTemplate DataType="{x:Type viewModels:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:RegisterViewModel}">
            <views:RegisterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TodoListViewModel}">
            <views:TodoListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AddTaskViewModel}">
            <views:TaskEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:EditTaskViewModel}">
            <views:TaskEditView />
        </DataTemplate>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,4,8,4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,4,0,10" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,4,0,10" />
        </Style>
    </Application.Resources>
</Application>
