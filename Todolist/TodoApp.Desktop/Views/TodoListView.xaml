<UserControl x:Class="TodoApp.Desktop.Views.TodoListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Список задач"
                           FontSize="26"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding ProfileTitle}"
                           Foreground="#4B5563"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button DockPanel.Dock="Right"
                    Content="Выйти"
                    Width="110"
                    HorizontalAlignment="Right"
                    Command="{Binding LogoutCommand}" />
        </DockPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Поиск по тексту" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Статус" />
                    <ComboBox ItemsSource="{Binding StatusFilters}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding SelectedStatusFilter}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="Дата от" />
                    <DatePicker SelectedDate="{Binding DateFrom}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="Дата до" />
                    <DatePicker SelectedDate="{Binding DateTo}" />
                </StackPanel>

                <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                    <Button Content="Применить"
                            Width="115"
                            Command="{Binding ApplyFiltersCommand}" />
                    <Button Content="Сбросить"
                            Width="115"
                            Command="{Binding ResetFiltersCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding SelectedTask}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#D1D5DB"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Текст"
                                    Binding="{Binding Text}"
                                    Width="*" />
                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding StatusDisplay}"
                                    Width="150" />
                <DataGridTextColumn Header="Дата обновления"
                                    Binding="{Binding LastUpdate, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                    Width="180" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding Message}"
                       VerticalAlignment="Center"
                       Foreground="#4B5563" />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Добавить"
                        Width="120"
                        Command="{Binding AddCommand}" />
                <Button Content="Редактировать"
                        Width="130"
                        Command="{Binding EditCommand}" />
                <Button Content="Удалить"
                        Width="110"
                        Command="{Binding DeleteCommand}" />
                <ComboBox Width="140"
                          ItemsSource="{Binding Statuses}"
                          SelectedItem="{Binding SelectedNewStatus}" />
                <Button Content="Изменить статус"
                        Width="150"
                        Command="{Binding ChangeStatusCommand}" />
                <Button Content="Обновить"
                        Width="110"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
