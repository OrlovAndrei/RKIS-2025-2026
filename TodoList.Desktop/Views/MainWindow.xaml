<Window x:Class="TodoListDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:TodoListDesktop.ViewModels"
        xmlns:views="clr-namespace:TodoListDesktop.Views"
        Title="TodoList"
        Width="980"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:RegisterViewModel}">
            <views:RegisterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TodoListViewModel}">
            <views:TodoListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AddTaskViewModel}">
            <views:AddTaskView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:EditTaskViewModel}">
            <views:EditTaskView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="TodoList"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="WPF-клиент для задач из SQLite"
                           Foreground="#666666"
                           Margin="0,4,0,0" />
            </StackPanel>
        </DockPanel>

        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
