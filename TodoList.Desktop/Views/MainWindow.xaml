<Window x:Class="TodoListWpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TodoList"
        Width="920"
        Height="560"
        MinWidth="720"
        MinHeight="440"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="TodoList"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="WPF-клиент для задач из SQLite"
                           Foreground="#666666"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Button Content="Обновить"
                    Command="{Binding RefreshCommand}"
                    Padding="14,8"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right" />
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                     MinHeight="38"
                     VerticalContentAlignment="Center"
                     Padding="10,0"
                     FontSize="14" />

            <Button Grid.Column="1"
                    Content="Добавить"
                    Command="{Binding AddTaskCommand}"
                    Padding="18,8"
                    Margin="10,0,0,0" />
        </Grid>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding SelectedTask}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding Id}"
                                    IsReadOnly="True"
                                    Width="60" />
                <DataGridTextColumn Header="Задача"
                                    Binding="{Binding Text}"
                                    IsReadOnly="True"
                                    Width="*" />
                <DataGridComboBoxColumn Header="Статус"
                                        SelectedItemBinding="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{Binding DataContext.StatusOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Width="160" />
                <DataGridTextColumn Header="Обновлена"
                                    Binding="{Binding LastUpdate, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                    IsReadOnly="True"
                                    Width="170" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#555555"
                       VerticalAlignment="Center" />

            <Button Content="Удалить выбранную"
                    Command="{Binding DeleteTaskCommand}"
                    Padding="14,8"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right" />
        </DockPanel>
    </Grid>
</Window>
