<UserControl x:Class="TodoApp.Desktop.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border Width="460" Padding="28" Background="White" CornerRadius="6"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.12"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Регистрация" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18"/>

                <TextBlock Text="Логин"/>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Пароль"/>
                <PasswordBox PasswordChanged="PasswordBox_OnPasswordChanged"/>

                <TextBlock Text="Имя"/>
                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Фамилия"/>
                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Год рождения"/>
                <TextBox Text="{Binding BirthYear, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="{Binding Message}" Foreground="#B3261E" TextWrapping="Wrap" Margin="0,4,0,10"/>

                <Button Content="Зарегистрироваться" Command="{Binding RegisterCommand}" Background="#1F6FEB" Foreground="White"/>
                <Button Content="Назад ко входу" Command="{Binding ShowLoginCommand}" Background="#EEF2F7"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
