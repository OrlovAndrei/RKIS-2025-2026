<Window x:Class="TodoApp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Todo App" Height="650" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Button Content="← Назад" Command="{Binding GoBackCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="10,5" Padding="10,5"
                    IsEnabled="{Binding CanGoBack}"/>
        </Border>
        <ContentControl Content="{Binding CurrentViewModel}"/>
    </DockPanel>
</Window>