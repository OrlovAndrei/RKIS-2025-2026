<UserControl x:Class="TodoApp.Desktop.Views.TodoListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:TodoApp.Desktop.ViewModels"
             xmlns:converters="clr-namespace:TodoApp.Desktop.Converters"
             d:DataContext="{d:DesignInstance Type=vm:TodoListViewModel}"
             d:DesignHeight="500" d:DesignWidth="800">
    <DockPanel>
        <!-- Верхняя панель с фильтрами, поиском и кнопками -->
        <StackPanel DockPanel.Dock="Top" Margin="10">
            <TextBlock Text="{Binding CurrentProfile.Name, StringFormat='Задачи пользователя: {0}'}" 
                       FontWeight="Bold" 
                       Margin="0,0,0,10"/>

            <WrapPanel>
                <TextBox Width="200" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0" />

                <ComboBox ItemsSource="{Binding Source={StaticResource TodoStatusValues}}"
                          SelectedValue="{Binding FilterStatus}"
                          Width="120" Margin="5,0" />

                <CheckBox Content="По убыванию" 
                          IsChecked="{Binding SortDescending}" 
                          Margin="10,0" />

                <Button Content="Добавить задачу" 
                        Command="{Binding AddTaskCommand}" 
                        Margin="10,0"/>

                <Button Content="Редактировать" 
                        Command="{Binding EditTaskCommand}"
                        IsEnabled="{Binding IsTaskSelected}"
                        Margin="5,0"/>

                <Button Content="Удалить" 
                        Command="{Binding DeleteTaskCommand}"
                        IsEnabled="{Binding IsTaskSelected}"
                        Margin="5,0"/>

                <Button Content="Выйти" 
                        Command="{Binding LogoutCommand}" 
                        Margin="20,0,0,0"/>
            </WrapPanel>
        </StackPanel>

        <!-- Список задач -->
        <ListView ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding SelectedTask}"
                  MouseDoubleClick="ListView_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Текст" 
                                    DisplayMemberBinding="{Binding Text}" 
                                    Width="250"/>
                    <GridViewColumn Header="Статус" 
                                    DisplayMemberBinding="{Binding Status}" 
                                    Width="100"/>
                    <GridViewColumn Header="Изменён" 
                                    DisplayMemberBinding="{Binding LastUpdate, StringFormat='dd.MM.yyyy HH:mm'}" 
                                    Width="140"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>