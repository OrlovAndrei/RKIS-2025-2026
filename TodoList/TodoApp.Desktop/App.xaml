<Application x:Class="TodoApp.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:models="clr-namespace:TodoApp.Models;assembly=TodoApp.Models"
             xmlns:converters="clr-namespace:TodoApp.Desktop.Converters"
             xmlns:vm="clr-namespace:TodoApp.Desktop.ViewModels"
             xmlns:views="clr-namespace:TodoApp.Desktop.Views">
    <Application.Resources>
        <!-- Конвертер -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- Источник значений TodoStatus для ComboBox -->
        <ObjectDataProvider x:Key="TodoStatusValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:TodoStatus" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- Сопоставление ViewModel → View -->
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <views:RegisterView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TodoListViewModel}">
            <views:TodoListView />
        </DataTemplate>
    </Application.Resources>
</Application>