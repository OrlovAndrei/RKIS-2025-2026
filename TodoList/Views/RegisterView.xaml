<UserControl x:Class="TodoApp.Desktop.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" Padding="15">
            <TextBlock Text="Регистрация" FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="350" Margin="20">
                <TextBlock Text="Логин" Margin="0,0,0,4"/>
                <TextBox Margin="0,0,0,10" Padding="10" Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Пароль" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10" Padding="10"/>
                <TextBlock Text="Подтверждение пароля" Margin="0,0,0,4"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,10" Padding="10"/>
                <TextBlock Text="Имя" Margin="0,0,0,4"/>
                <TextBox Margin="0,0,0,10" Padding="10" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Фамилия" Margin="0,0,0,4"/>
                <TextBox Margin="0,0,0,10" Padding="10" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Год рождения" Margin="0,0,0,4"/>
                <TextBox Margin="0,0,0,10" Padding="10" Text="{Binding BirthYear, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="Зарегистрироваться" Margin="0,10,0,5" Padding="10" Command="{Binding RegisterCommand}" Style="{StaticResource PrimaryButton}"/>
                <Button Content="Назад к входу" Margin="0,5,0,10" Padding="10" Command="{Binding NavigateToLoginCommand}" Style="{StaticResource SecondaryButton}"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
                <ProgressBar IsIndeterminate="True" Height="4" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
